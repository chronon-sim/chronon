# Chronon API Documentation - Doxygen Configuration

PROJECT_NAME           = "Chronon"
PROJECT_BRIEF          = "High-Performance Tick-Based Simulation Framework"
PROJECT_NUMBER         = ""
OUTPUT_DIRECTORY       = build/doxygen

# Input sources: public API + key internals
INPUT                  = src/chronon \
                         src/sender/core \
                         src/sender/port \
                         src/sender/util \
                         src/sender/app \
                         src/sender/config \
                         src/sender/factory \
                         src/observe \
                         src/params \
                         src/tree
RECURSIVE              = NO
FILE_PATTERNS          = *.hpp
EXCLUDE_PATTERNS       = */detail/* */internal/*

# Extraction settings
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO

# C++ specific
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = CHRONON_EXPORT=

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# Output formats
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = YES

# Graph generation (disabled for XML-only output)
HAVE_DOT               = NO

# Warnings
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
QUIET                  = YES

# Namespace handling
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_NAMESPACES        = YES
BUILTIN_STL_SUPPORT    = NO
